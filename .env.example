# OctoFinance Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ---------------------------------------------------------------------------
# GitHub PAT — source of truth. Change token here and restart to apply.
# ---------------------------------------------------------------------------
GITHUB_PAT=ghp_your_token_here

# Enterprise slug(s) — comma-separated if multiple.
# Required if your org is under a GitHub Enterprise account.
# Find in your enterprise URL: github.com/enterprises/YOUR-SLUG
ENTERPRISE_SLUG=your-enterprise-slug

# ---------------------------------------------------------------------------
# Seed admin user
# If SEED_USER_ENABLED=true, OctoFinance will auto-create (or update) this
# user with super_admin role on every startup.
# ---------------------------------------------------------------------------
SEED_USER_ENABLED=true
SEED_USER_USERNAME=admin
SEED_USER_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Sync settings
# AUTO_SYNC_ON_STARTUP: true/false — sync data when the server starts
# SYNC_CRON: cron expression, e.g. "0 */6 * * *" (every 6h), "*/30 * * * *" (every 30m)
#            Leave empty or set to "off" to disable scheduled sync.
# ---------------------------------------------------------------------------
AUTO_SYNC_ON_STARTUP=true
SYNC_CRON=0 */6 * * *
